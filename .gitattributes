# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# JSON files
*.json text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Audio
*.mp3 binary
*.wav binary
*.ogg binary
*.flac binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary

# Databases
*.db binary
*.sqlite binary
*.pickle binary

# Exclude from exports
.gitignore export-ignore
.gitattributes export-ignore
